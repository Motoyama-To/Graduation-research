# --- YOLOクロップ関数 ---
def detect_and_crop_animal(image, yolo_model):
    results = yolo_model(image, verbose=False)[0]

    if results.boxes is None or len(results.boxes) == 0:
        return image, "unknown"

    max_area = 0
    best_crop = image
    detected_label = "unknown"

    h, w = image.shape[:2]

    for box in results.boxes:
        cls_id = int(box.cls[0])
        label = yolo_model.names[cls_id]

        if label not in ["cat", "dog"]:
            continue
        
        x1, y1, x2, y2 = map(int, box.xyxy[0])
        x1 = max(0, x1)
        y1 = max(0, y1)
        x2 = min(w, x2)
        y2 = min(h, y2)

        # 不正bbox除外
        if x2 <= x1 or y2 <= y1:
            continue

        area = (x2 - x1) * (y2 - y1)

        if area > max_area:
            max_area = area
            best_crop = image[y1:y2, x1:x2]
            detected_label = label

    return best_crop, detected_label

# --- ResNet18 CNN ---
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

weights = models.ResNet18_Weights.DEFAULT
resnet = models.resnet18(weights=weights)

# 最後の分類層(fc)を削除
resnet = torch.nn.Sequential(
    *list(resnet.children())[:-1]
)
resnet.eval()
resnet.to(device)

def extract_cnn_features(image):

    image_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)

    tensor = cnn_transform(image_rgb).unsqueeze(0).to(device)

    with torch.no_grad():
        features = resnet(tensor)

    features = features.squeeze().cpu().numpy()

    return features

# --- 特徴量抽出関数 ---
def extract_features(image):
    if image is None:
        return None
    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)

    # CNN 全体特徴
    cnn_features = extract_cnn_features(image)
    
    
    # Color Histogram  毛色
    hsv = cv2.cvtColor(image, cv2.COLOR_BGR2HSV)
    hist_h = cv2.calcHist([hsv], [0], None, [180], [0, 180]).flatten()
    hist_s = cv2.calcHist([hsv], [1], None, [256], [0, 256]).flatten()
    hist_v = cv2.calcHist([hsv], [2], None, [256], [0, 256]).flatten()
    color_features = np.concatenate((hist_h, hist_s, hist_v))
    if color_features.sum() > 0:
        color_features /= color_features.sum()
    

    # --- Grid Local Features（局所特徴） ---
    grid_features = []

    h, w = image.shape[:2]

    grid_h = h // 3
    grid_w = w // 3

    for i in range(3):
        for j in range(3):

            cell = image[
                i * grid_h:(i + 1) * grid_h,
                j * grid_w:(j + 1) * grid_w
            ]

            # 空画像対策
            if cell.size == 0:
                continue

            # HSV変換
            hsv_cell = cv2.cvtColor(cell, cv2.COLOR_BGR2HSV)

            # Hヒストグラム
            hist_h = cv2.calcHist(
                [hsv_cell],
                [0],
                None,
                [16],
                [0, 180]
            ).flatten()

            # 正規化
            hist_h = hist_h.astype(np.float32)
            hist_h /= (hist_h.sum() + 1e-7)

            # Gray
            gray_cell = cv2.cvtColor(cell, cv2.COLOR_BGR2GRAY)

            # エッジ量
            edges = cv2.Canny(gray_cell, 100, 200)
            edge_density = np.sum(edges > 0) / edges.size

            # LBP
            lbp_cell = local_binary_pattern(
                gray_cell,
                P=8,
                R=1,
                method="uniform"
            )

            lbp_hist, _ = np.histogram(
                lbp_cell.ravel(),
                bins=16,
                range=(0, 16)
            )

            lbp_hist = lbp_hist.astype(np.float32)
            lbp_hist /= (lbp_hist.sum() + 1e-7)

            # 特徴追加
            grid_features.extend(hist_h)
            grid_features.extend(lbp_hist)
            grid_features.append(edge_density)

    grid_features = np.array(grid_features, dtype=np.float32)

    combined = np.concatenate((
        cnn_features * 3.0,
        color_features * 0.3,
        grid_features * 1.5
    ))

    return combined


# --- 特徴量の名前と範囲を定義 ---
def get_feature_info(image_size):
    cnn_dim = 512
    color_dim = 180 + 256 + 256
    grid_dim = (16 + 16 + 1) * 9

    feature_info = {
        'CNN': {
            'start': 0,
            'end': cnn_dim
        },

        'Color Histogram': {
            'start': cnn_dim,
            'end': cnn_dim + color_dim
        },

        'Grid Local Features': {
            'start': cnn_dim + color_dim,
            'end': cnn_dim + color_dim + grid_dim
        }
    }
    return feature_info

# --- 類似猫犬の検出と予測（強化版・説明機能追加） ---
def find_and_display_similar_dogs_and_cats_with_prediction(
    query_image_path,
    model,
    scaler,
    pca_model,
    X_train_reduced,
    y_train,
    filepaths_train,
    class_names,
    feature_info,
    rf_no_pca,
    animal_type
):
    print("\n>> --- 類似猫犬検出・品種推定 ---")
    
    query_img = cv2.imread(query_image_path)
    query_img , _ = detect_and_crop_animal(query_img, yolo_model)
    
    if query_img is None:
        print(f"エラー: クエリ画像を読み込めません: {query_image_path}")
        return
    query_img_resized = cv2.resize(query_img, IMAGE_SIZE)
    
    # オリジナル特徴量の抽出
    query_features = extract_features(query_img_resized)
    
    if query_features is None:
        print("エラー: クエリ画像から特徴量を抽出できませんでした。")
        return
    
    # PCAを適用
    query_features_scaled = scaler.transform(query_features.reshape(1, -1))
    query_features_reduced = pca_model.transform(query_features_scaled)

    # 1. 品種を推定
    predicted_label_idx = model.predict(query_features_reduced)[0]
    predicted_breed_name = class_names[predicted_label_idx]

    # --- Wikipediaで推定品種名を検索 ---
    # 最初に「品種名 + 猫」で検索し、曖昧さ回避やページエラーの場合は「品種名」単体で再試行
    search_queries = [predicted_breed_name + f" {animal_type}", predicted_breed_name]
    breed_description = "品種の説明が見つかりませんでした。"
    
    for query in search_queries:
        try:
            breed_description = wikipedia.summary(query, sentences=3)
            # 成功した場合、ループを抜ける
            break 
        except wikipedia.exceptions.DisambiguationError as e:
            if e.options:
                # 曖昧さ回避の場合、最初の候補を試す
                try:
                    breed_description = wikipedia.summary(e.options[0], sentences=3)
                    break
                except Exception:
                    # 最初の候補もダメなら次のクエリへ
                    continue
            else:
                # 候補がない場合は次のクエリへ
                continue
        except wikipedia.exceptions.PageError:
            # ページが見つからない場合は次のクエリへ
            continue
        except Exception as e:
            # その他のエラーが発生した場合
            breed_description = f"Wikipediaから説明を取得中にエラーが発生しました: {e}"
            break # 深刻なエラーのためループを抜ける
    
    # どちらの検索でも見つからなかった場合、最終メッセージを生成
    if breed_description == "品種の説明が見つかりませんでした。":
        breed_description = f"Wikipediaページ '{predicted_breed_name}'（または '{predicted_breed_name} 猫'）に関する有効な説明が見つかりませんでした。"
    
    print(f"推定品種名: {predicted_breed_name}")
    print(f"品種説明: {breed_description}")
  

    # 2. 個別の予測に対する説明を可視化
    
    importances = rf_no_pca.feature_importances_
    
    # 特徴量グループごとの重要度を合計
    original_feature_importance_map = {}
    
    for name, info in feature_info.items():
        original_feature_importance_map[name] = np.sum(importances[info['start']:info['end']])

    sorted_importances = sorted(original_feature_importance_map.items(), key=lambda item: item[1], reverse=True)
    
    fig, ax = plt.subplots(figsize=(10, 6))
    
    feature_names = [item[0] for item in sorted_importances]
    importance_values = [item[1] for item in sorted_importances]
    
    ax.bar(feature_names, importance_values, color='skyblue')
    ax.set_title(f"品種 '{predicted_breed_name}' と判断した理由")
    ax.set_xlabel("特徴量タイプ")
    ax.set_ylabel("重要度")
    
    plt.xticks(rotation=45, ha='right')
    plt.tight_layout()
    plt.show()

    # 3. 類似度を計算（品種ラベルの重み付けを導入）
    distances = []
    original_query_filepath = os.path.abspath(query_image_path)
    
    X_train_reduced = normalize(X_train_reduced)
    query_features_reduced = normalize(
        query_features_reduced
    )

    sims = cosine_similarity(query_features_reduced, X_train_reduced)[0]
    distances = []
    for i, sim in enumerate(sims):
        dist = 1 - sim
        if y_train[i] != predicted_label_idx:
            dist *= 1.5
        distances.append((dist, filepaths_train[i], y_train[i]))
    distances.sort(key=lambda x: x[0])

    print("\n>> --- 最も類似する猫犬の画像（類似度・同品種優先） ---")
    
    plt.figure(figsize=(15, 5))
    
    MAX_DISPLAY = 10
    displayed_count = 0
    displayed_same_breed_count = 0
    displayed_original_filepaths = set()
    
    for dist, filepath_augmented, label in distances:
        if displayed_count >= MAX_DISPLAY:
            break
        if filepath_augmented not in displayed_original_filepaths:
            
            img = cv2.imread(filepath_augmented)

            if filepath_augmented in cropped_cache:
                img = cropped_cache[filepath_augmented]
            else:
                img, _ = detect_and_crop_animal(img, yolo_model)
                if img is None:
                    continue
                cropped_cache[filepath_augmented] = img

            img_resized = cv2.resize(img, IMAGE_SIZE)
            img_to_display = cv2.cvtColor(img_resized, cv2.COLOR_BGR2RGB)
            
            ax = plt.subplot(2, 5, displayed_count + 1)
            ax.imshow(img_to_display)
            ax.set_title(f"品種: {class_names[label]}\n距離: {dist:.2f}")
            ax.axis('off')

            displayed_count += 1
            displayed_original_filepaths.add(filepath_augmented)
            if label == predicted_label_idx:
                displayed_same_breed_count += 1

    if displayed_count == 0:
        print("類似画像を表示できませんでした。")
    plt.tight_layout()
    plt.show()


