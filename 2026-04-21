        gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

        _, desc = sift_extractor.detectAndCompute(gray, None)

        if desc is not None:
            all_descriptors.append(desc)

    # descriptorが1つもない場合の対策
    if len(all_descriptors) == 0:
        raise ValueError("SIFT特徴量が1つも抽出できませんでした")

    all_descriptors = np.vstack(all_descriptors)

    print(f"SIFT descriptor数: {all_descriptors.shape}")

    # kmeans（BoVW）
    n_clusters = min(64, len(all_descriptors))
    kmeans = MiniBatchKMeans(n_clusters=n_clusters, random_state=RANDOM_STATE)
