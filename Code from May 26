            img_resized = cv2.resize(img, IMAGE_SIZE)
            img_to_display = cv2.cvtColor(img_resized, cv2.COLOR_BGR2RGB)
            
            ax = plt.subplot(2, 5, displayed_count + 1)
            ax.imshow(img_to_display)
            ax.set_title(f"品種: {class_names[label]}\n距離: {dist:.2f}")
            ax.axis('off')

            displayed_count += 1
            displayed_original_filepaths.add(filepath_augmented)
            if label == predicted_label_idx:
                displayed_same_breed_count += 1

    if displayed_count == 0:
        print("類似画像を表示できませんでした。")
    plt.tight_layout()
    plt.show()












